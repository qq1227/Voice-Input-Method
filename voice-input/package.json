{
  "name": "voice-input",
  "version": "1.0.0",
  "description": "语音输入法 - 基于 Electron + Vosk 的高性能语音识别输入工具",
  "main": "electron-dist/electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "dev": "concurrently --kill-others \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "download-model": "node scripts/download-model.js",
    "test": "npx jest --config tests/jest.config.ts --verbose",
    "test:ci": "npx jest --config tests/jest.config.ts --verbose --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "npx jest --config tests/jest.config.ts --verbose --coverage",
    "test:watch": "npx jest --config tests/jest.config.ts --verbose --watch",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.voiceinput.app",
    "productName": "语音输入法",
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "models/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "jest-junit": "^16.0.0"
  },
  "optionalDependencies": {
    "vosk": "^0.3.45"
  }
}
